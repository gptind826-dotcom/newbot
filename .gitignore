# eXuCoDeR Music Bot - Git Ignore

# Environment
.env
*.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Downloads & Cache
downloads/*
