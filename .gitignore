anony/cookies/*.txt
!anony/cookies/.gitkeep

# Logs
*.log
log.txt

# Sessions
*.session
*.session-journal

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# uv
.venv/
uv.lock
