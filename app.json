{
    "name": "eXuCoDeR Music Bot",
    "description": "Professional Telegram music streaming bot with auto-cleanup",
    "keywords": ["telegram", "music", "bot", "voice-chat", "streaming"],
    "repository": "https://github.com/gptind826-dotcom/newbot",
    "logo": "https://files.catbox.moe/zvziwk.jpg",
    "stack": "container",
    "env": {
        "API_ID": {
            "description": "Your Telegram API ID (from my.telegram.org)",
            "required": true
        },
        "API_HASH": {
            "description": "Your Telegram API Hash (from my.telegram.org)",
            "required": true
        },
        "BOT_TOKEN": {
            "description": "Your bot token (from @BotFather)",
            "required": true
        },
        "MONGO_URL": {
            "description": "MongoDB connection string",
            "required": true
        },
        "LOGGER_ID": {
            "description": "Logger group/channel ID",
            "required": true
        },
        "OWNER_ID": {
            "description": "Your Telegram user ID",
            "required": true
        },
        "SESSION": {
            "description": "Pyrogram session string",
            "required": true
        }
    },
    "buildpacks": [
        {
            "url": "heroku/python"
        }
    ],
    "formation": {
        "worker": {
            "quantity": 1,
            "size": "basic"
        }
    }
}
